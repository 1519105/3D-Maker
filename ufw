# Instalace
sudo apt install -y ufw

# Default policy
sudo ufw default deny incoming
sudo ufw default allow outgoing

# SSH z LAN
sudo ufw allow from 192.168.88.0/24 to any port 22 proto tcp

# Veškerý provoz z Tailscale (SSH, web, API, kamera - vše)
sudo ufw allow in on tailscale0

# Mainsail/Fluidd web UI
sudo ufw allow from 192.168.88.0/24 to any port 80 proto tcp
sudo ufw allow from 192.168.88.0/24 to any port 443 proto tcp

# Moonraker API
sudo ufw allow from 192.168.88.0/24 to any port 7125 proto tcp

# Crowsnest (kamera)
sudo ufw allow from 192.168.88.0/24 to any port 8080 proto tcp

# mDNS (.local resolving)
sudo ufw allow from 192.168.88.0/24 to any port 5353 proto udp

# Aktivace
sudo ufw enable

# Kontrola
sudo ufw status verbose
